# انسخ إلى .env على الخادم أو انسخ القيم في لوحة Hostinger → Docker → Environment.
# Copy to .env on the server or paste into Hostinger Docker environment UI.

# كلمة مرور Postgres — يجب أن تطابق ما يُحقن في DATABASE_URL تلقائياً عبر compose
POSTGRES_PASSWORD=change_me_strong_password

# عنوان IP العام أو اسم النطاق الذي يفتحه المتصفح للوصول إلى واجهة/API
VPS_IP=203.0.113.10

JWT_SECRET=replace_with_long_random_string_min_32_chars

WAHA_API_KEY=replace_with_random_api_key
# WAHA_SESSION_NAME=default
